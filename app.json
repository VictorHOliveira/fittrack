{
  "expo": {
    "name": "Treino Mais",
    "slug": "AppGymTraining",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "appgymtraining",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.victorhugooliveira87.AppGymTraining",
      "googleServicesFile": "./google-services.json",
      "versionCode": 4
    },
    "splash": {
      "backgroundColor": "#1a1a2e",
      "image": "./assets/icon.png",
      "resizeMode": "contain"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6C63FF"
        }
      ],
      "expo-sharing",
      "expo-splash-screen",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-audio"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b32b9e3e-b418-49d1-be54-8cd4ae2b5d4a"
      }
    },
    "owner": "victorhugooliveira87"
  }
}
